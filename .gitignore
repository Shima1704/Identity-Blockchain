# Dependencies
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production builds
build/
dist/
.next/
out/

# Environment files (actual)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local
ai-services/.env

# Keep example files
!**/.env.example
!**/.env.local.example

# Uploaded files & user data - ignore all files but keep directories
backend/src/uploads/cccd/*
backend/src/uploads/faces/*
ai-services/uploads/cccd/*

# Keep upload directories by allowing .gitkeep files
!backend/src/uploads/cccd/.gitkeep
!backend/src/uploads/faces/.gitkeep  
!ai-services/uploads/cccd/.gitkeep

