# App
NODE_ENV=development
PORT=3000
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://identity_user:identity_pass@localhost:5432/identity_db

# Redis
REDIS_URL=redis://localhost:6379

# Blockchain
BLOCKCHAIN_RPC_URL=http://localhost:8545
CHAIN_ID=1337
IDENTITY_CONTRACT_ADDRESS=
ACCESS_CONTROL_CONTRACT_ADDRESS=
CREDENTIAL_CONTRACT_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# AI Services
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Encryption
AES_SECRET_KEY=your_aes_256_key_here_32_chars_min
