# App
APP_ENV=development
PORT=8000

# Face Recognition
FACE_MATCH_THRESHOLD=0.95
LIVENESS_CONFIDENCE_THRESHOLD=0.98
MAX_RETRY_ATTEMPTS=3

# OCR
OCR_ENGINE=easyocr
CCCD_NUMBER_PATTERN=^\d{12}$

# Redis
REDIS_URL=redis://localhost:6379

# Security
API_KEY=your_ai_service_api_key_here
TEMP_FILE_TTL_SECONDS=60
